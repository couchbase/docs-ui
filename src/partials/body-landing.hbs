<div class="body container">
{{#if (eq nav 'full')}}
{{> nav}}
{{> toc}}
{{else if (eq nav 'tutorials-filter')}}
{{> tutorials-filter}}
{{else if (eq nav 'sidebar')}}
{{#if (eq (nav-mode) 'client')}}
{{#with (nav-group-for-page (nav-groups))}}
{{#if ./components.length}}
<aside class="nav left-sidebar">
  <div class="nav-container">
    <a href="#" class="menu-expand-toggle"><span>Navigation</span><i class="fas fa-times-circle"></i><i class="fas fa-chevron-circle-left"></i></a>
  </div>
</aside>
{{/if}}
{{/with}}
{{/if}}
{{/if}}
<main class="{{or mainClass 'article'}}" data-ceiling="topbar">
{{> llms-guidance}}
{{> watermark}}
<article class="doc landing-page-doc{{#if articleClass}} {{articleClass}}{{/if}}">
{{#if capellaImages}}
<img class="opening-image" src="{{{uiRootPath}}}/img/stars.svg" />
{{/if}}
{{{page.contents}}}
{{#if capellaImages}}
<img class="ending-image" src="{{{uiRootPath}}}/img/lineplus.svg" />
{{/if}}
</article>
</main>
</div>
